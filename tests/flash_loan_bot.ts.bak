// ---------------------------------------------------------------------------
// CONSTANTES — Tokens
// ---------------------------------------------------------------------------
const USDC_MINT = new PublicKey("EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v");
const WSOL_MINT = new PublicKey("So11111111111111111111111111111111111111112");

// ---------------------------------------------------------------------------
// CONSTANTES — Raydium AMM V4
// ---------------------------------------------------------------------------
const RAYDIUM = {
    program:          new PublicKey("675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8"),
    ammId:            new PublicKey("58oQChx4yWmvKdwLLZzBi4ChoCc2fqCUWBkwMihLYQo2"),
    ammAuthority:     new PublicKey("5Q544fKrFoe6tsEbD7S8EmxGTJYAKtTVhAW5Q5pge4j1"),
    ammOpenOrders:    new PublicKey("HmiHHzq4Fym9e1D4qzLS6LDDM3tNsCTBPDWHTLZ763jY"),
    ammTargetOrders:  new PublicKey("CZza3Ej4Mc58MnxWA385itCC9jCo3L1D7zc3LKy1bZMR"),
    ammCoinVault:     new PublicKey("DQyrAcCrDXQ7NeoqGgDCZwBvWDcYmFCjSb9JtteuvPpz"),
    ammPcVault:       new PublicKey("HLmqeL62xR1QoZ1HKKbXRrdN1p3phKpxRMb2VVopvBBz"),
    serumProgram:     new PublicKey("srmqPvymJeFKQ4zGQed1GFppgkRHL9kaELCbyksJtPX"),
    serumMarket:      new PublicKey("8BnEgHoWFysVcuFFX7QztDmzuH8r5ZFvyP3sYwn1XTh6"),
    serumBids:        new PublicKey("5jWUncPNBMZJ3sTHKmMLszypVkoRK6bfEQMQUHweeQnh"),
    serumAsks:        new PublicKey("EaXdHx7x3mdGA38j5RSmKYSXMzAFzzUXCLNBEDXDn1d5"),
    serumEventQueue:  new PublicKey("8CvwxZ9Db6XbLD46NZwwmVDZZRDy7eydFcAGkXKh9axa"),
    serumCoinVault:   new PublicKey("CKxTHwM9fPMRRvZmFnFoqKNd9pQR21c5Aq9bh5h9oghX"),
    serumPcVault:     new PublicKey("6A5NHCj1yF6urc9wZNe6Bcjj4LVszQNj5DwAWG97yzMu"),
    serumVaultSigner: new PublicKey("CTz5UMLQm2SRWHzQnU62Pi4yJqbNGjgRBHqqp6oDHfF7"),
};

// ---------------------------------------------------------------------------
// CONSTANTES — Orca Whirlpool
// ---------------------------------------------------------------------------
const ORCA = {
    program:    new PublicKey("whirLbMiicVdio4qvUfM5KAg6Ct8VwpYzGff3uctyCc"),
    pool:       new PublicKey("HJPjoWUrhoZzkNfRpHuieeFk9WcZWjwy6PBjZ81ngndJ"),
    oracle:     new PublicKey("4GkRbcYg1VKsZropgai4dMf2Nj2PkXNLf43knFpavrSi"),
    vaultA:     new PublicKey("3YQm7ujtXWJU2e9jhp2QGHpnn1ShXn12QjvzMvDgabpX"),
    vaultB:     new PublicKey("2JTw1fE2wz1SymWUQ7UqpVtrTuKjcd6mWwYwUJUCh2rq"),
    tickArray0: new PublicKey("A2W6hiA2nf16iqtbZt9vX8FJbiXjv3DBUG3DgTja61HT"),
    tickArray1: new PublicKey("2Eh8HEeu45tCWxY6ruLLRN6VcTSD7bfshGj7bZA87Kne"),
    tickArray2: new PublicKey("CEstjhG1v4nUgvGDyFruYEbJ18X8XeN4sX1WFCLt4D5c"),
};

// ---------------------------------------------------------------------------
// CONFIGURAÇÃO
// ---------------------------------------------------------------------------
const LOAN_AMOUNT_USDC = 1;    // 1 USDC para validar o fluxo
const SLIPPAGE_BPS     = 50;   // 0.5%

// ---------------------------------------------------------------------------
// UTILITÁRIOS
// ---------------------------------------------------------------------------
function applySlippage(amount: anchor.BN, bps: number): anchor.BN {
    return amount.muln(10000 - bps).divn(10000);
}

function getSighash(name: string): Buffer {
    return Buffer.from(sha256(`global:${name}`)).subarray(0, 8);
}

async function sendWithFreshBlockhash(
    connection: Connection,
    payer: Keypair,
    instructions: TransactionInstruction[]
): Promise<string> {
    for (let attempt = 0; attempt < 5; attempt++) {
        try {
            const { blockhash, lastValidBlockHeight } =
                await connection.getLatestBlockhash("confirmed");
            const tx = new anchor.web3.Transaction();
            tx.recentBlockhash = blockhash;
            tx.feePayer = payer.publicKey;
            instructions.forEach(ix => tx.add(ix));
            tx.sign(payer);
            const sig = await connection.sendRawTransaction(tx.serialize(), {
                skipPreflight: false,
            });
            await connection.confirmTransaction(
                { signature: sig, blockhash, lastValidBlockHeight },
                "confirmed"
            );
            return sig;
        } catch (e: any) {
            if (attempt === 4) throw e;
            await new Promise(r => setTimeout(r, 1000));
        }
    }
    throw new Error("sendWithFreshBlockhash: todas as tentativas falharam.");
}

async function waitForLookupTable(
    connection: Connection,
    address: PublicKey,
    expectedCount: number
): Promise<AddressLookupTableAccount> {
    console.log(`⏳ Aguardando LUT com ${expectedCount} endereços...`);
    for (let i = 0; i < 60; i++) {
        const result = (
            await connection.getAddressLookupTable(address, { commitment: "confirmed" })
        ).value;
        if (result && result.state.addresses.length >= expectedCount) {
            console.log(`✅ LUT pronta: ${result.state.addresses.length} endereços.`);
            return result;
        }
        await new Promise(r => setTimeout(r, 1000));
    }
    throw new Error("LUT não ficou pronta em 60s.");
}

// ---------------------------------------------------------------------------
// SUITE
// ---------------------------------------------------------------------------
describe("flash_loan_full_cycle", () => {
    const provider   = anchor.AnchorProvider.env();
    anchor.setProvider(provider);

    const program    = anchor.workspace.FlashLoanBot as Program<FlashLoanBot>;
    const BOT_ID     = program.programId;
    const user       = provider.wallet;
    const connection = provider.connection;

    let userUsdcAccount: PublicKey;
    let userWsolAccount: PublicKey;

    before(async () => {
        userUsdcAccount = await getAssociatedTokenAddress(USDC_MINT, user.publicKey);
        userWsolAccount = await getAssociatedTokenAddress(WSOL_MINT, user.publicKey);

        await createAssociatedTokenAccountIdempotent(
            connection, (user as any).payer, USDC_MINT, user.publicKey
        );
        await createAssociatedTokenAccountIdempotent(
            connection, (user as any).payer, WSOL_MINT, user.publicKey
        );

        console.log("✅ Setup concluído");
        console.log("   USDC ATA:", userUsdcAccount.toBase58());
        console.log("   WSOL ATA:", userWsolAccount.toBase58());
    });

    it("Ciclo atômico: Start → Borrow → Raydium → Orca → Repay → End", async () => {
        const amountLoan  = new anchor.BN(LOAN_AMOUNT_USDC * 1_000_000);
        const minSolOut   = applySlippage(amountLoan, SLIPPAGE_BPS);
        const minUsdcBack = applySlippage(amountLoan, SLIPPAGE_BPS);

        console.log(`📋 Loan:     ${amountLoan.toString()} (${LOAN_AMOUNT_USDC} USDC)`);
        console.log(`📋 Min SOL:  ${minSolOut.toString()}`);
        console.log(`📋 Min USDC: ${minUsdcBack.toString()}`);

        // -------------------------------------------------------------------
        // LOOKUP TABLE
        // -------------------------------------------------------------------
        const slot = await connection.getSlot("confirmed");
        const [createLutIx, lutAddress] = AddressLookupTableProgram.createLookupTable({
            authority:  user.publicKey,
            payer:      user.publicKey,
            recentSlot: slot - 1,
        });

        const allAddresses: PublicKey[] = [
            // Marginfi
            MARGINFI_PROGRAM, MARGINFI_GROUP, MARGINFI_ACCOUNT,
            USDC_BANK, LIQUIDITY_VAULT, LIQUIDITY_VAULT_AUTH,
            INSTRUCTIONS_SYSVAR,
            // Raydium
            RAYDIUM.program,        RAYDIUM.ammId,          RAYDIUM.ammAuthority,
            RAYDIUM.ammOpenOrders,  RAYDIUM.ammTargetOrders,
            RAYDIUM.ammCoinVault,   RAYDIUM.ammPcVault,
            RAYDIUM.serumProgram,   RAYDIUM.serumMarket,    RAYDIUM.serumBids,
            RAYDIUM.serumAsks,      RAYDIUM.serumEventQueue,
            RAYDIUM.serumCoinVault, RAYDIUM.serumPcVault,   RAYDIUM.serumVaultSigner,
            // Orca
            ORCA.program,    ORCA.pool,       ORCA.oracle,
            ORCA.vaultA,     ORCA.vaultB,
            ORCA.tickArray0, ORCA.tickArray1, ORCA.tickArray2,
            // Geral
            USDC_MINT, WSOL_MINT, BOT_ID, TOKEN_PROGRAM_ID,
            userUsdcAccount, userWsolAccount,
        ];

        await sendWithFreshBlockhash(connection, (user as any).payer, [createLutIx]);
        console.log("✅ LUT criada:", lutAddress.toBase58());

        const CHUNK = 20;
        for (let i = 0; i < allAddresses.length; i += CHUNK) {
            const n = Math.floor(i / CHUNK) + 1;
            const t = Math.ceil(allAddresses.length / CHUNK);
            await sendWithFreshBlockhash(connection, (user as any).payer, [
                AddressLookupTableProgram.extendLookupTable({
                    payer: user.publicKey, authority: user.publicKey,
                    lookupTable: lutAddress,
                    addresses: allAddresses.slice(i, i + CHUNK),
                }),
            ]);
            console.log(`   Chunk ${n}/${t} confirmado`);
        }

        const lutAccount = await waitForLookupTable(connection, lutAddress, allAddresses.length);

        await new Promise(r => setTimeout(r, 4000));
        const { blockhash } = await connection.getLatestBlockhash("confirmed");

        // -------------------------------------------------------------------
        // Tx layout:
        //   0 = ComputeBudget
        //   1 = StartFlashloan  ← end_index = 6
        //   2 = Borrow
        //   3 = Raydium
        //   4 = Orca
        //   5 = Repay
        //   6 = EndFlashloan
        // -------------------------------------------------------------------
        const END_INDEX = 6n;

        // INSTRUÇÃO 1 — START FLASHLOAN


            const ixStart = new TransactionInstruction({
            programId: MARGINFI_PROGRAM,
 
             data: Buffer.concat([
                  Buffer.from([14, 131, 33, 220, 81, 186, 180, 107]),
                 Buffer.from(new BigInt64Array([END_INDEX]).buffer),
              ]),



           keys: [
              { pubkey: MARGINFI_ACCOUNT,    isSigner: false, isWritable: true  },
              { pubkey: user.publicKey,       isSigner: true,  isWritable: false },
              { pubkey: INSTRUCTIONS_SYSVAR, isSigner: false, isWritable: false },
          ],



        });

        // INSTRUÇÃO 2 — BORROW
        const ixBorrow = new TransactionInstruction({
            programId: BOT_ID,
            data: Buffer.concat([
                getSighash("marginfi_borrow"),
                amountLoan.toArrayLike(Buffer, "le", 8),
            ]),
            keys: [
                { pubkey: MARGINFI_GROUP,        isSigner: false, isWritable: false },
                { pubkey: MARGINFI_ACCOUNT,      isSigner: false, isWritable: true  },
                { pubkey: user.publicKey,         isSigner: true,  isWritable: false },
                { pubkey: USDC_BANK,             isSigner: false, isWritable: true  },
                { pubkey: userUsdcAccount,        isSigner: false, isWritable: true  },
                { pubkey: LIQUIDITY_VAULT_AUTH,  isSigner: false, isWritable: false },
                { pubkey: LIQUIDITY_VAULT,       isSigner: false, isWritable: true  },
                { pubkey: TOKEN_PROGRAM_ID,      isSigner: false, isWritable: false },
                { pubkey: MARGINFI_PROGRAM,      isSigner: false, isWritable: false },
            ],
        });

        // INSTRUÇÃO 3 — RAYDIUM: USDC → SOL
        const ixRaydium = new TransactionInstruction({
            programId: BOT_ID,
            data: Buffer.concat([
                getSighash("proxy_raydium"),
                amountLoan.toArrayLike(Buffer, "le", 8),
                minSolOut.toArrayLike(Buffer, "le", 8),
            ]),
            keys: [
                { pubkey: user.publicKey,            isSigner: true,  isWritable: true  },
                { pubkey: userUsdcAccount,           isSigner: false, isWritable: true  },
                { pubkey: userWsolAccount,           isSigner: false, isWritable: true  },
                { pubkey: TOKEN_PROGRAM_ID,          isSigner: false, isWritable: false },
                { pubkey: RAYDIUM.program,           isSigner: false, isWritable: false },
                { pubkey: RAYDIUM.ammId,             isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.ammAuthority,      isSigner: false, isWritable: false },
                { pubkey: RAYDIUM.ammOpenOrders,     isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.ammTargetOrders,   isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.ammCoinVault,      isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.ammPcVault,        isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.serumProgram,      isSigner: false, isWritable: false },
                { pubkey: RAYDIUM.serumMarket,       isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.serumBids,         isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.serumAsks,         isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.serumEventQueue,   isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.serumCoinVault,    isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.serumPcVault,      isSigner: false, isWritable: true  },
                { pubkey: RAYDIUM.serumVaultSigner,  isSigner: false, isWritable: false },
            ],
        });

        // INSTRUÇÃO 4 — ORCA: SOL → USDC
        const ixOrca = new TransactionInstruction({
            programId: BOT_ID,
            data: Buffer.concat([
                getSighash("proxy_orca"),
                minSolOut.toArrayLike(Buffer, "le", 8),
                minUsdcBack.toArrayLike(Buffer, "le", 8),
            ]),
            keys: [
                { pubkey: TOKEN_PROGRAM_ID, isSigner: false, isWritable: false },
                { pubkey: user.publicKey,   isSigner: true,  isWritable: false },
                { pubkey: ORCA.program,     isSigner: false, isWritable: false },
                { pubkey: ORCA.pool,        isSigner: false, isWritable: true  },
                { pubkey: userWsolAccount,  isSigner: false, isWritable: true  },
                { pubkey: ORCA.vaultA,      isSigner: false, isWritable: true  },
                { pubkey: userUsdcAccount,  isSigner: false, isWritable: true  },
                { pubkey: ORCA.vaultB,      isSigner: false, isWritable: true  },
                { pubkey: ORCA.tickArray0,  isSigner: false, isWritable: true  },
                { pubkey: ORCA.tickArray1,  isSigner: false, isWritable: true  },
                { pubkey: ORCA.tickArray2,  isSigner: false, isWritable: true  },
                { pubkey: ORCA.oracle,      isSigner: false, isWritable: true }, 
                 

            ],
        });

        // INSTRUÇÃO 5 — REPAY
        const ixRepay = new TransactionInstruction({
            programId: BOT_ID,
            data: Buffer.concat([
                getSighash("marginfi_repay"),
                amountLoan.toArrayLike(Buffer, "le", 8),
                Buffer.from([1, 1]), // repay_all: Some(true)
            ]),
            keys: [
                { pubkey: MARGINFI_GROUP,      isSigner: false, isWritable: false },
                { pubkey: MARGINFI_ACCOUNT,    isSigner: false, isWritable: true  },
                { pubkey: user.publicKey,       isSigner: true,  isWritable: false },
                { pubkey: USDC_BANK,           isSigner: false, isWritable: true  },
                { pubkey: userUsdcAccount,      isSigner: false, isWritable: true  },
                { pubkey: LIQUIDITY_VAULT,     isSigner: false, isWritable: true  },
                { pubkey: TOKEN_PROGRAM_ID,    isSigner: false, isWritable: false },
                { pubkey: MARGINFI_PROGRAM,    isSigner: false, isWritable: false },
            ],
        });

        // INSTRUÇÃO 6 — END FLASHLOAN

         const ixEnd = new TransactionInstruction({
            programId: MARGINFI_PROGRAM,
            data: Buffer.from([105, 124, 201, 106, 153, 2, 8, 156]),
            keys: [
                { pubkey: MARGINFI_ACCOUNT, isSigner: false, isWritable: true  },
                { pubkey: user.publicKey,   isSigner: true,  isWritable: false },
            ],
        });


        // -------------------------------------------------------------------
        // MONTA TX V0
        // -------------------------------------------------------------------
        const messageV0 = new TransactionMessage({
            payerKey:        user.publicKey,
            recentBlockhash: blockhash,
            instructions: [
                ComputeBudgetProgram.setComputeUnitLimit({ units: 1_400_000 }),
                ixStart,   // 1
                ixBorrow,  // 2
                ixRaydium, // 3
                ixOrca,    // 4
                ixRepay,   // 5
                ixEnd,     // 6
            ],
        }).compileToV0Message([lutAccount]);

        const txV0 = new VersionedTransaction(messageV0);
        txV0.sign([(user as any).payer]);

        // -------------------------------------------------------------------
        // SIMULA
        // -------------------------------------------------------------------
        console.log("🔍 Simulando...");
        const sim = await connection.simulateTransaction(txV0, {
            sigVerify:  false,
            commitment: "confirmed",
        });

        if (sim.value.err) {
            console.error("❌ Simulação falhou:");
            sim.value.logs?.forEach(l => console.log(" ", l));
            throw new Error(`Simulação falhou: ${JSON.stringify(sim.value.err)}`);
        }

        console.log("✅ Simulação OK:");
        sim.value.logs?.forEach(l => console.log(" ", l));

        // -------------------------------------------------------------------
        // ENVIA
        // -------------------------------------------------------------------
        const txId = await connection.sendTransaction(txV0, {
            skipPreflight:       false,
            maxRetries:          3,
            preflightCommitment: "confirmed",
        });

        console.log(`\n✅ SUCESSO! Assinatura: ${txId}`);
        console.log(`   https://explorer.solana.com/tx/${txId}`);
    });
});
